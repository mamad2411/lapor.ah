# ===========================================
# Lapor.ah Landing — Environment Variables
# Salin ke .env.local
# ===========================================

# URL aplikasi Next.js (untuk link token di email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Client (Console → Project settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Console → Service accounts → Generate key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Wajib untuk upload media (sama dengan NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Email OTP — Gmail SMTP gratis (App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=app-password-gmail
SMTP_FROM=email@gmail.com

# WhatsApp OTP gratis (opsional) — daftar di https://green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=

# WhatsApp OTP via Fonnte (Rekomendasi) — daftar di https://fonnte.com
FONNTE_TOKEN=

# Secret bootstrap superadmin & sesi operasional
SUPERADMIN_SECRET=ganti-dengan-secret-panjang-superadmin
OPS_SESSION_SECRET=ganti-dengan-secret-sesi-terpisah

# Google reCAPTCHA v2 "I'm not a robot" (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
