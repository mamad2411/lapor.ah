/*
  # ──────────────────────────────────────────────────────────────────
  # Security Headers — diterapkan Netlify CDN (di depan Next.js)
  # Cloudflare juga menambahkan perlindungan tambahan jika dikonfigurasi
  # sebagai proxy di depan Netlify.
  # ──────────────────────────────────────────────────────────────────

  # Proteksi MIME sniffing
  X-Content-Type-Options: nosniff

  # Cegah clickjacking
  X-Frame-Options: DENY

  # Legacy XSS filter
  X-XSS-Protection: 1; mode=block

  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # HSTS 2 tahun (akan masuk Chromium HSTS preload list)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Batasi fitur browser berbahaya
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(), usb=(), bluetooth=(), interest-cohort=()

  # Isolasi cross-origin (relaxed for Leaflet & Firebase)
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Resource-Policy: cross-origin

  # Cegah DNS prefetch
  X-DNS-Prefetch-Control: off

  # Hapus informasi server
  X-Powered-By: (removed)

  # Cache default untuk halaman HTML — no-store agar tidak bocor ke CDN
  Cache-Control: no-store

/api/*
  # API tidak boleh di-cache
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff

/_next/static/*
  # Asset statis — cache permanen (hash di URL menjamin freshness)
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/sw.js
  # Service worker — selalu fresh
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /
